{
  "_meta": {
    "version": 1,
    "description": "行为规则库（Rule-Based Constraints）。用于将确定性常识/恢复策略下沉到符号层，减少 Prompt 幻觉，提高鲁棒性。",
    "note": "本文件为 Phase 3/4 的落地起点：先定义数据结构，再逐步让 Executor/Resolver 消费这些规则。"
  },
  "thresholds": {
    "owner_fallback_distance": 50,
    "goto_owner_reached_distance": 5,
    "default_search_radius": 24,
    "default_gather_count": 32,
    "max_action_retries_l1": 3,
    "max_l1_failures_before_unstuck_l2": 3
  },
  "deictic_anchor_keywords": [
    "我这边",
    "我这里",
    "我附近",
    "我旁边",
    "离我最近",
    "离我",
    "这边",
    "这里",
    "旁边",
    "附近"
  ],
  "implicit_tasks": {
    "gather_owner_fallback": {
      "enabled": true,
      "when": {
        "task_types": ["mine", "explore"],
        "scan_empty": true,
        "distance_bot_owner_gt": 50
      },
      "then": {
        "action": "goto_owner",
        "description": "扫描不到目标且离主人太远，先向主人区域移动（假设主人附近资源更丰富）"
      }
    }
  },
  "recovery": {
    "L1_action_retry": {
      "enabled": true,
      "max_retries": 3,
      "strategies": [
        { "type": "retry_same_action" },
        { "type": "random_micro_move", "params": { "max_delta": 1 } }
      ]
    },
    "L2_unstuck": {
      "enabled": true,
      "after_consecutive_l1_failures": 3,
      "strategies": [
        { "type": "unstuck_backoff" },
        { "type": "unstuck_step_up" }
      ]
    },
    "L3_inventory_full": {
      "enabled": true,
      "on_error_codes": ["INVENTORY_FULL"],
      "strategy": { "type": "report_and_block", "reason": "背包已满，等待主人处理" }
    },
    "L4_overall_timeout": {
      "enabled": true,
      "strategy": { "type": "goto_owner_and_idle", "reason": "超时回主人身边待命" }
    }
  }
}


