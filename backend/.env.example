# MC_Servant Backend Environment Variables Template
# 复制此文件为 .env 并填写实际值

# =============================================
# WebSocket 服务器配置
# =============================================
MC_SERVANT_WS_HOST=0.0.0.0
MC_SERVANT_WS_PORT=8765

# =============================================
# Minecraft 服务器配置
# =============================================
MC_SERVANT_MC_HOST=mc.hcid274.xyz
MC_SERVANT_MC_PORT=25565

# =============================================
# Bot 配置
# =============================================
MC_SERVANT_BOT_USERNAME=MCServant_Bot
MC_SERVANT_BOT_PASSWORD=YourBotPassword

# =============================================
# LLM 配置 (通义千问 Qwen-Flash)
# =============================================
# 阿里云 DashScope API Key (获取地址: https://dashscope.console.aliyun.com/)
MC_SERVANT_OPENAI_API_KEY=sk-your-dashscope-api-key

# OpenAI 兼容 API 地址 (固定值，无需修改)
MC_SERVANT_OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认模型 (qwen-flash 速度快成本低，qwen-max 能力强但 JSON 输出不稳定)
MC_SERVANT_OPENAI_MODEL=qwen-flash

# =============================================
# 日志配置
# =============================================
MC_SERVANT_LOG_LEVEL=INFO
