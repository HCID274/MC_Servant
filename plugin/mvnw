# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup script, version 3.2.0
# ----------------------------------------------------------------------------

# Determine the script directory
if [ -z "$MAVEN_BASEDIR" ]; then
  MAVEN_BASEDIR=$(cd "$(dirname "$0")" && pwd -P)
fi

# Read wrapper properties
WRAPPER_PROPERTIES="$MAVEN_BASEDIR/.mvn/wrapper/maven-wrapper.properties"
if [ ! -f "$WRAPPER_PROPERTIES" ]; then
  echo "Error: Could not find $WRAPPER_PROPERTIES" >&2
  exit 1
fi

DIST_URL=$(grep "^distributionUrl=" "$WRAPPER_PROPERTIES" | cut -d'=' -f2-)
MAVEN_VERSION=$(echo "$DIST_URL" | sed 's/.*apache-maven-\([0-9.]*\).*/\1/')

# Set Maven home
MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-$MAVEN_VERSION"
MVN_CMD="$MAVEN_HOME/bin/mvn"

# Download and extract if needed
if [ ! -x "$MVN_CMD" ]; then
  echo "Downloading Maven $MAVEN_VERSION..."
  
  DOWNLOAD_DIR="$HOME/.m2/wrapper/dists"
  mkdir -p "$DOWNLOAD_DIR"
  
  ZIP_FILE="$DOWNLOAD_DIR/apache-maven-$MAVEN_VERSION-bin.zip"
  
  # Download
  if command -v curl > /dev/null; then
    curl -fsSL -o "$ZIP_FILE" "$DIST_URL"
  elif command -v wget > /dev/null; then
    wget -q -O "$ZIP_FILE" "$DIST_URL"
  else
    echo "Error: curl or wget is required" >&2
    exit 1
  fi
  
  # Extract
  echo "Extracting Maven..."
  unzip -q -o "$ZIP_FILE" -d "$DOWNLOAD_DIR"
  rm -f "$ZIP_FILE"
  chmod +x "$MVN_CMD"
  
  echo "Maven $MAVEN_VERSION installed successfully."
fi

# Find Java
if [ -z "$JAVA_HOME" ]; then
  JAVA_CMD=$(command -v java)
else
  JAVA_CMD="$JAVA_HOME/bin/java"
fi

if [ ! -x "$JAVA_CMD" ]; then
  echo "Error: JAVA_HOME is not set and java command not found in PATH." >&2
  exit 1
fi

export JAVA_HOME

# Run Maven
exec "$MVN_CMD" "$@"
